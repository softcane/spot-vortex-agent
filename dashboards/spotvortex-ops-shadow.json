      "id": 1,
      "type": "timeseries",
      "title": "Decision Recommendations by Source and Action (15m Increase)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "expr": "sum by (source, action) (increase(spotvortex_decision_source_total[15m]))",
          "legendFormat": "{{source}} / {{action}}",
          "refId": "A"
        }
      ]
